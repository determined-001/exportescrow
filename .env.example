# Solana — client-facing (used by wallet adapter)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Solana — server-side overrides (optional; default to NEXT_PUBLIC_* values).
# Useful if the server should use a paid RPC endpoint (Helius, Triton) while
# the browser uses a public one.
SOLANA_RPC_URL=
USDC_MINT_ADDRESS=

# Protocol fee payer (base58-encoded 64-byte ed25519 secret key).
# Pays rent + tx fees for multisig creation, ATA derivation, and release
# transactions. Generate with `solana-keygen new -o fee-payer.json` and then
# base58-encode the secret-key array. See scripts/README.md.
FEE_PAYER_PRIVATE_KEY=

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# KIRAPAY (confirm package + endpoints in docs.kira-pay.com)
KIRAPAY_API_KEY=
KIRAPAY_API_BASE_URL=https://api.kira-pay.com
KIRAPAY_WEBHOOK_SECRET=

# Pinata (IPFS)
PINATA_JWT=
PINATA_GATEWAY=
